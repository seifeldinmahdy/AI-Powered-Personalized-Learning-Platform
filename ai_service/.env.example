# AI Service Environment Variables
# Copy this file to .env and fill in your values

# Internal service-to-service shared secret.
# Must match Django's INTERNAL_SERVICE_KEY. Used by /intent/reload and other
# service-only endpoints.
INTERNAL_SERVICE_KEY=

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_CODING=qwen/qwen3-32b
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_API_KEY=your_ollama_api_key_here
# Coding question generation backend:
#   hybrid = T5 (fine-tuned) for basic topics + LLM enrichment; LLM-only for advanced (default)
#   llm    = LLM for all topics
#   t5     = force T5 for all topics (debug)
CODING_QG_BACKEND=hybrid
