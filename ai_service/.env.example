# AI Service Environment Variables
# Copy this file to .env and fill in your values

# Internal service-to-service shared secret.
# Must match Django's INTERNAL_SERVICE_KEY. Used by /intent/reload and other
# service-only endpoints.
INTERNAL_SERVICE_KEY=

# Vector store backend shared with rag_pipeline. "chroma" (local, default) or
# "supabase" (shared pgvector). Must match the other services so everyone reads
# the same corpus. SUPABASE_DB_URL = pooled Supabase Postgres URI (port 6543).
VECTOR_BACKEND=chroma
SUPABASE_DB_URL=
VECTOR_EMBEDDING_DIM=384

# Course-pathway PLAN store backend. "sqlite" (local, default) or "supabase"
# (shared Postgres — uses the SAME SUPABASE_DB_URL as the corpus above). Explicit
# opt-in: unlike the vector store this never auto-switches. Run
# course_pathway/sql/pathway_setup.sql once, then migrate existing plans with
# course_pathway/scripts/migrate_sqlite_to_supabase.py.
PATHWAY_BACKEND=sqlite

# Student-context store backend. "file" (local JSON, default) or "supabase"
# (shared Postgres — reuses SUPABASE_DB_URL). Write-once/read-only; no bloat.
# Run ai_service/sql/ai_stores_setup.sql once, then migrate existing contexts
# with ai_service/scripts/migrate_student_contexts_to_supabase.py. Reversible.
STUDENT_CONTEXT_BACKEND=file

# ── Text-to-speech backend ──────────────────────────────────────────
# "edge" (default, cloud, no GPU) or "chatterbox" (Chatterbox Turbo, local GPU).
# On any Chatterbox load/synthesis failure the service falls back to Edge.
TTS_BACKEND=edge
# Chatterbox Turbo settings (only used when TTS_BACKEND=chatterbox):
CHATTERBOX_DEVICE=cuda
# Optional HF model id / local path for the Turbo weights (blank = package default):
CHATTERBOX_MODEL=
# Optional 8-10s reference clip to give Dr. Nova a consistent voice (blank = built-in):
CHATTERBOX_REF_CLIP=
# Override the import if the installed package exposes a different class:
# CHATTERBOX_IMPORT=chatterbox.tts:ChatterboxTTS

