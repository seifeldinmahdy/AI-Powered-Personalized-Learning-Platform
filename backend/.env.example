DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=postgres
DB_USER=postgres.your-supabase-project-ref
DB_PASSWORD=your-db-password
DB_HOST=aws-0-region.pooler.supabase.com
DB_PORT=6543
CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_SERVICE_URL=http://localhost:8001

# Vector store backend for the corpus auto-tagger (concept→chunk tagging). Must
# match the AI service / rag_pipeline. "chroma" (local) or "supabase" (shared
# pgvector). The vectors can live in this SAME Supabase project (a course_chunks
# table alongside the Django tables) — set SUPABASE_DB_URL to its pooled URI.
VECTOR_BACKEND=chroma
SUPABASE_DB_URL=
VECTOR_EMBEDDING_DIM=384

# Shared secret for service-to-service authentication.
# Must match the AI service's INTERNAL_SERVICE_KEY.
INTERNAL_SERVICE_KEY=change-me-in-production

# Absolute path to Intent_Classifier_Model directory (used by retraining command).
INTENT_CLASSIFIER_MODEL_DIR=./Intent_Classifier_Model

REDIS_URL=redis://127.0.0.1:6379/1

# ---------- Social OAuth (server-side secrets) ----------
# Create OAuth apps in each provider's console and set the redirect/callback
# to:  http://localhost:3000/auth/callback/<provider>   (and your prod origin).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------- Capstone GitHub App (auto repo provisioning) ----------
# NOTE: these are SEPARATE from the GITHUB_CLIENT_ID/SECRET above (those are for
# OAuth login). This is a GitHub *App* the platform uses to create each student's
# private capstone repo, set branch protection, invite them, and read CI status.
#
# Setup (see the step-by-step guide):
#   1. Create a GitHub org           → GITHUB_ORG (the org name)
#   2. Create a GitHub App in the org with Repository permissions:
#        Administration: Read & write, Contents: Read & write, Checks: Read-only
#        (Metadata: Read-only is automatic). Install it on "All repositories".
#   3. App settings page             → GITHUB_APP_ID
#   4. "Generate a private key" (.pem) → GITHUB_APP_PRIVATE_KEY (see note below)
#   5. After installing, the install URL's trailing number → GITHUB_APP_INSTALLATION_ID
# Requires: pip install PyJWT cryptography
GITHUB_ORG=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# The PEM private key. Paste it as a single line with literal \n for newlines
# (the app un-escapes them), e.g.:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
# Convert a .pem to one line:  awk 'BEGIN{ORS="\\n"} {print}' your-key.pem
GITHUB_APP_PRIVATE_KEY=
# Optional — only if you enable the App's webhook (live CI push notifications).
# Grading works without it (CI status is read directly), so it can stay blank for
# local testing. If set, must match the App's webhook secret.
GITHUB_WEBHOOK_SECRET=
