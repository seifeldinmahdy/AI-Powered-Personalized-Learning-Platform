# Ollama Cloud Configuration
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_API_KEY=your_api_key_here

# Retry settings
MAX_RETRIES=3

# Vector store backend: "chroma" (local, default) or "supabase" (shared pgvector).
# Leave unset to auto-pick supabase whenever SUPABASE_DB_URL is present.
VECTOR_BACKEND=chroma
# Supabase Postgres connection string — use the POOLED URI (port 6543).
# Run rag_pipeline/sql/pgvector_setup.sql once, then migrate with
# scripts/migrate_chroma_to_supabase.py. Embedder dim must match VECTOR_EMBEDDING_DIM.
SUPABASE_DB_URL=
VECTOR_EMBEDDING_DIM=384

# Course-pathway PLAN store backend. "sqlite" (local, default) or "supabase"
# (shared Postgres — reuses the SUPABASE_DB_URL above). Explicit opt-in; never
# auto-switches. Setup: course_pathway/sql/pathway_setup.sql, then migrate with
# course_pathway/scripts/migrate_sqlite_to_supabase.py.
PATHWAY_BACKEND=sqlite

# ChromaDB (used only when VECTOR_BACKEND=chroma)
CHROMA_DB_PATH=./data/chroma
CHROMA_COLLECTION_NAME=course_chunks

# Chunking
CHUNK_SIZE_TOKENS=350
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG
TOP_K=5

# Paths
RAW_BOOKS_DIR=./raw_books
